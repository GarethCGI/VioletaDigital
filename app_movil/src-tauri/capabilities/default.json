{
	"$schema": "../gen/schemas/desktop-schema.json",
	"identifier": "default",
	"description": "Capability for the main window",
	"windows": [
		"main"
	],
	"permissions": [
		"core:default",
		"opener:default",
		"http:default",
		"pinia:default",
		"core:event:default",
		{
			"identifier": "http:default",
			"allow": [
				{
					"url": "http://*"
				},
				{
					"url": "https://*"
				},
				{
					"url": "http://*:*"
				},
				{
					"url": "https://*:*"
				},
				{
					"url": "http://violetadigital.ddns.our-space.xyz:19132/*"
				}
			]
		}
	]
}